SQLACC_AWS_REGION=ap-southeast-1
SESSION_SECRET=change-me-to-64-random-hex-chars
LOG_DIR=./logs
DOC_TYPES_FILE=./doc_types.json
COMPANIES_FILE=./companies.json
USERS_FILE=./users.json
DEFAULT_TEMPLATES_FILE=./default_templates.json

# Server binding (optional — defaults shown).
# Production behind nginx: HOST=127.0.0.1 and SHOW=false.
# Override PORT if 8090 is taken (e.g. local dev).
# HOST=0.0.0.0
# PORT=8090
# SHOW=true
